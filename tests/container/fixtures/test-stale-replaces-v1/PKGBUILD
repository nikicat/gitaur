# Foreign baseline for case 11. pkgname=test-stale-replaces at v1.0,
# staged as a `.pkg.tar.zst` under /srv/foreign-pkgs/. The smoke test
# applies it with `pacman -U` to seed an older install of the same
# pkgname the AUR fixture ships at v2.0 — so the trigger
# `aurox -S test-stale-replaces` exercises the Pkgname-beats-stale-Replaces
# guard end-to-end through alpm → counterpart → review trace.
#
# Directory name diverges from pkgname on purpose: setup-fixtures iterates
# fixture directories as pkgbases, but the produced .pkg.tar.zst is named
# after `pkgname`, so this directory ships the v1.0 artifact for the same
# pkgname the AUR fixture next door publishes at v2.0. `install_foreign
# test-stale-replaces` globs by pkgname and picks up this file.
pkgname=test-stale-replaces
pkgver=1.0
pkgrel=1
pkgdesc='aurox test fixture: older baseline for the stale-replaces case'
arch=('any')
license=('MIT')

package() {
    install -Dm644 /dev/null "$pkgdir/usr/share/$pkgname/marker"
}
