# Deliberately failing build(): drives the resilience tests for the AUR
# pipeline (smoke/28-30). Echoes a fixed sentinel to stderr so the
# build.log capture test can grep for it. Independent of any other
# fixture so it can be paired with a succeeding sibling pkgbase.
pkgname=test-fail-build
pkgver=1.0
pkgrel=1
pkgdesc='gitaur test fixture: build() returns 1'
arch=('any')
license=('MIT')

build() {
    echo 'GITAUR_FAIL_BUILD_SENTINEL' >&2
    return 1
}

package() {
    install -Dm644 /dev/null "$pkgdir/usr/share/$pkgname/marker"
}
