# Lives in the local sync repo; used as a makedep by test-with-makedep so
# aurox has to install it from pacman (--asdeps) before driving makepkg.
pkgname=repo-helper-lib
pkgver=1.0
pkgrel=1
pkgdesc='aurox test fixture: helper lib in sync repo'
arch=('any')
license=('MIT')

package() {
    install -Dm644 /dev/null "$pkgdir/usr/share/$pkgname/marker"
}
